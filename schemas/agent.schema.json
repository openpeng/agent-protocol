{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agent-protocol.org/schemas/agent.schema.json",
  "title": "Agent Protocol v3.0 - agent.json",
  "description": "Schema for agent.json v3.0 specification",
  "type": "object",
  "required": ["schema_version", "identity", "entry", "subagents"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "3.0",
      "description": "Schema version identifier"
    },
    "identity": {
      "type": "object",
      "required": ["name", "version", "description", "author"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
          "description": "Agent unique identifier in kebab-case"
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+(-[a-z0-9]+)?$",
          "description": "Semantic version (e.g., 1.0.0, 2.1.3-beta)"
        },
        "display_name": {
          "type": "string",
          "description": "Human-readable display name"
        },
        "description": {
          "type": "string",
          "minLength": 10,
          "maxLength": 200,
          "description": "Short description (10-200 characters)"
        },
        "author": {
          "type": "string",
          "description": "Author name or organization"
        },
        "license": {
          "type": "string",
          "default": "MIT",
          "description": "License identifier (SPDX format)"
        },
        "homepage": {
          "type": "string",
          "format": "uri",
          "description": "Homepage URL"
        },
        "repository": {
          "type": "string",
          "format": "uri",
          "description": "Source repository URL"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
          },
          "minItems": 1,
          "maxItems": 10,
          "description": "Search tags (kebab-case)"
        }
      }
    },
    "entry": {
      "type": "object",
      "required": ["main_subagent"],
      "properties": {
        "main_subagent": {
          "type": "string",
          "description": "Entry point subagent name"
        }
      }
    },
    "subagents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "path"],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$",
            "description": "Subagent unique name (snake_case)"
          },
          "path": {
            "type": "string",
            "pattern": "\\.(yaml|yml)$",
            "description": "Path to worker.yaml file"
          },
          "description": {
            "type": "string",
            "description": "Subagent description"
          }
        }
      }
    },
    "dependencies": {
      "type": "object",
      "properties": {
        "python3": {
          "type": "string",
          "description": "Python version requirement (e.g., >=3.10)"
        },
        "nodejs": {
          "type": "string",
          "description": "Node.js version requirement (e.g., >=18.0.0)"
        },
        "llm_provider": {
          "type": "string",
          "enum": ["anthropic", "openai", "azure", "any"],
          "description": "Required LLM provider"
        }
      },
      "additionalProperties": {
        "type": "string"
      }
    },
    "category": {
      "type": "string",
      "enum": [
        "development",
        "productivity",
        "writing",
        "research",
        "data",
        "security",
        "testing",
        "documentation",
        "refactoring",
        "general"
      ],
      "description": "Agent category"
    },
    "type": {
      "type": "string",
      "enum": ["agent", "skill", "workflow"],
      "description": "Agent type classification"
    },
    "instructions": {
      "oneOf": [
        {
          "type": "string",
          "description": "Inline instructions (v2 compatibility)"
        },
        {
          "type": "object",
          "properties": {
            "format": {
              "type": "string",
              "enum": ["markdown", "yaml", "text"]
            },
            "source": {
              "type": "string",
              "enum": ["inline", "file"]
            },
            "content": {
              "type": "string"
            },
            "file": {
              "type": "string"
            }
          }
        }
      ],
      "description": "Static instructions (v2 compatibility)"
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Agent capabilities (v2 compatibility)"
    },
    "compatibility": {
      "type": "object",
      "description": "Platform compatibility info (v2 compatibility)"
    }
  }
}
